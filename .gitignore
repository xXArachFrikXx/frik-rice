# ── Auto-generated by matugen (rebuilt on first theme switch) ─────────────────
# These files change every time you switch themes. They're excluded from git
# because install.sh runs apply-preset.sh at the end to regenerate them.
configs/.config/hypr/Modules/colors.lua
configs/.config/hypr/colors.conf
configs/.config/waybar/colors.css
configs/.config/kitty/colors.conf
configs/.config/rofi/colors.rasi
configs/.config/cava/config
configs/.config/wlogout/style.css
configs/.config/btop/themes/matugen.theme

# ── Waybar active-style symlink ────────────────────────────────────────────────
# style.css is a symlink pointing to the currently active style in style/.
# The actual style files (solid-buttons.css etc.) ARE tracked.
configs/.config/waybar/style.css

# ── MPD runtime files ─────────────────────────────────────────────────────────
# The database, state, and log files are generated by MPD at runtime.
# The config file (mpd.conf) IS tracked.
configs/.config/mpd/database
configs/.config/mpd/log
configs/.config/mpd/state
configs/.config/mpd/sticker.sql
configs/.config/mpd/playlists/

# ── Secrets and credentials ───────────────────────────────────────────────────
*.token
*.secret
*.key
*_token
*credentials*

# ── Kitty backup ─────────────────────────────────────────────────────────────
configs/.config/kitty/kitty.conf.bak

# ── Rofi copy ─────────────────────────────────────────────────────────────────
configs/.config/rofi/config\ (Copy).rasi

# ── System-specific / large files not needed on another machine ───────────────
configs/.config/spicetify/
configs/.config/obsidian/
configs/.config/FreeTube/
configs/.config/MusicBrainz/
configs/.config/vesktop/
configs/.config/yay/
configs/.config/go/
configs/.config/systemd/
configs/.config/pulse/
configs/.config/dconf/
